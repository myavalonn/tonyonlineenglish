<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>升學英文 - Tony Online English</title>
    <!-- 引入 Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Noto+Sans+TC:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        /* === 基礎全域設定 === */
        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            background-color: #1a1a1d; /* 桌機版的深色背景 */
            font-family: 'Noto Sans TC', -apple-system, BlinkMacSystemFont, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden; /* 防止桌機版產生多餘滾動條 */
        }

        /* === 桌機版：手機外框模型 === */
        .phone-wrapper {
            width: 430px;
            height: 888px;
            background-color: #000;
            border: 12px solid #2c2c2c;
            border-radius: 54px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
            position: relative;
            overflow: hidden;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        /* === 螢幕內部與背景圖 === */
        .phone-screen {
            background-image: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.2)), url('https://ik.imagekit.io/lql1uveoc/%E8%AA%B2%E7%A8%8B%E8%A9%B3%E7%B4%B0%E4%BB%8B%E7%B4%B9/benjamin-voros-phIFdC6lA4E-unsplash.jpg?updatedAt=1759344584590&tr=w-800,f-auto,q-70');
            background-size: cover;
            background-position: center;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            color: white;
            text-align: center;
            box-sizing: border-box;
            padding-top: 110px; /* 給狀態列與動態島留空間 */
            overflow-y: auto; /* 內容過多時可滾動 */
            -webkit-overflow-scrolling: touch;
        }

        /* === 頂部狀態列 (iOS 風格) === */
        .status-bar-container { position: absolute; top: 18px; left: 20px; right: 20px; height: 40px; z-index: 10; pointer-events: none; }
        .status-bar { height: 100%; display: flex; justify-content: space-between; align-items: center; color: white; font-size: 15px; font-weight: 600; padding: 0 15px; text-shadow: 1px 1px 2px rgba(0,0,0,0.5); }
        .time { position: absolute; left: 20px; }
        .status-icons { position: absolute; right: 20px; letter-spacing: 2px; }
        .dynamic-island { position: absolute; top: 2px; left: 50%; transform: translateX(-50%); width: 120px; height: 35px; background-color: #000; border-radius: 20px; z-index: 9; }

        /* === 內容區域 === */
        .menu {
            width: 100%;
            padding: 0 25px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            align-items: center;
            flex-grow: 1;
        }

        /* 玻璃感標題 */
        .glass-title {
            background: rgba(0,0,0,0.25);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 25px;
            padding: 15px 35px;
            margin-bottom: 30px;
            box-shadow: 0 4px 30px rgba(0,0,0,0.2);
        }

        .glass-title-text {
            font-size: 3.2em;
            font-weight: 900;
            color: #fff;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
            letter-spacing: 2px;
        }

        /* 按鈕群組 */
        .button-group {
            display: flex;
            flex-direction: column;
            gap: 16px;
            width: 100%;
            max-width: 350px; /* 限制按鈕最大寬度 */
        }

        /* 玻璃感按鈕 */
        .slide-button {
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: 700;
            color: white;
            text-decoration: none;
            padding: 18px;
            font-size: 1.3rem;
            letter-spacing: 1px;
            transition: all 0.2s ease;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 4px 25px rgba(0, 0, 0, 0.25);
            border-radius: 20px;
            background-color: rgba(255, 255, 255, 0.05);
        }

        .slide-button:hover, .slide-button:active {
            transform: scale(1.03);
            background-color: rgba(255, 255, 255, 0.15);
            border-color: rgba(255, 255, 255, 0.4);
        }

        /* 底部文字 */
        .footer-text {
            margin-top: auto;
            padding: 30px 0 40px;
            font-size: 1.1em;
            opacity: 0.8;
            letter-spacing: 1px;
        }

        /* === 響應式設計：平板與手機版 === */
        @media (max-width: 1024px) {
            html, body {
                background-color: #000;
            }
            .phone-wrapper {
                width: 100vw;
                height: 100vh;
                border: none;
                border-radius: 0;
                box-shadow: none;
            }
            .status-bar-container { display: none; /* 手機版不顯示假狀態列，讓給系統真的狀態列 */ }
            .phone-screen {
                padding-top: 60px; /* 手機版頂部留白縮減 */
            }
        }

        /* 超小螢幕手機微調 */
        @media (max-width: 375px) {
            .glass-title-text { font-size: 2.5em; }
            .slide-button { padding: 15px; font-size: 1.1rem; }
        }
    </style>
</head>
<body>

    <!-- 手機外觀容器 (桌機顯示邊框，手機則填滿螢幕) -->
    <div class="phone-wrapper">
        <div class="phone-screen">
            <!-- 假 iOS 狀態列 (僅桌機顯示) -->
            <div class="status-bar-container">
                <div class="dynamic-island"></div>
                <div class="status-bar">
                    <div class="time">9:41</div>
                    <div class="status-icons"><span>📶</span> <span>Wi-Fi</span> <span>🔋</span></div>
                </div>
            </div>

            <!-- 內容區域 -->
            <div class="menu">
                <div class="glass-title"><span class="glass-title-text">升學英文</span></div>
                
                <div class="button-group">
                    <a href="https://tonyonlineenglish.mydurable.com/elementary-school" class="slide-button" target="_blank">國小英文</a>
                    <a href="https://tonyonlineenglish.mydurable.com/junior-high-school" class="slide-button" target="_blank">國中會考</a>
                    <a href="https://tonyonlineenglish.mydurable.com/high-school" class="slide-button" target="_blank">高中英文學測＋<span style="color: #FFC300; font-weight: bold;">寫作</span></a>
                    <a href="https://tonyonlineenglish.mydurable.com/vochighschool" class="slide-button" target="_blank">技高統測英文＋<span style="color: #FF80AB; font-weight: bold;">作文</span></a>
                    <a href="https://tonyonlineenglish.mydurable.com/colleges" class="slide-button" target="_blank">大學英文</a>
                    <a href="https://tonyonlineenglish.mydurable.com/graduateschool" class="slide-button" target="_blank">研究所碩士英文</a>
                </div>

                <div class="footer-text">詳情請點擊上方各連結</div>
            </div>
        </div>
    </div>

</body>
</html>
