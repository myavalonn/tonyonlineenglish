<!-- Admin Panel v2.0 (Fix: Button always active) -->
<div style="font-family: 'Segoe UI', sans-serif; max-width: 600px; margin: 20px auto; padding: 20px; border: 1px solid #ddd; border-radius: 12px; background: #fff; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
  <h2 style="text-align:center; color:#333; border-bottom: 2px solid #ff5400; padding-bottom: 10px;">☀️ 週日特別開放管理</h2>
  
  <div style="margin-bottom: 20px;">
    <label style="font-weight:bold; display:block; margin-bottom:5px;">1. 選擇日期 (僅限週日)</label>
    <input type="date" id="admDate" style="width:100%; padding:12px; font-size:16px; border:1px solid #ccc; border-radius:6px;" onchange="checkSunday()">
  </div>

  <div style="margin-bottom: 20px;">
    <label style="font-weight:bold; display:block; margin-bottom:10px;">2. 勾選開放時段</label>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
      <label class="time-box"><input type="checkbox" value="10:00"> 10:00</label>
      <label class="time-box"><input type="checkbox" value="11:00"> 11:00</label>
      <label class="time-box"><input type="checkbox" value="12:00"> 12:00</label>
      <label class="time-box"><input type="checkbox" value="13:00"> 13:00</label>
      <label class="time-box"><input type="checkbox" value="14:00"> 14:00</label>
      <label class="time-box"><input type="checkbox" value="15:00"> 15:00</label>
      <label class="time-box"><input type="checkbox" value="16:00"> 16:00</label>
      <label class="time-box"><input type="checkbox" value="17:00"> 17:00</label>
      <label class="time-box"><input type="checkbox" value="18:00"> 18:00</label>
      <label class="time-box"><input type="checkbox" value="19:00"> 19:00</label>
      <label class="time-box"><input type="checkbox" value="20:00"> 20:00</label>
      <label class="time-box"><input type="checkbox" value="21:00"> 21:00</label>
    </div>
  </div>

  <button onclick="addException()" id="addBtn" style="width:100%; background: #28a745; color: white; padding: 15px; border: none; border-radius: 8px; font-size: 18px; cursor: pointer; font-weight: bold;">新增開放時段</button>
  <div id="statusMsg" style="margin-top:10px; text-align:center; font-weight:bold;"></div>
  
  <hr style="margin: 30px 0; border: 0; border-top: 1px solid #eee;">
  
  <h3>📋 目前已開放清單</h3>
  <!-- 這裡我改成了預設顯示無資料，才不會一直卡讀取中 -->
  <div id="loading" style="text-align:center; color:#666;">檢查資料中...</div>
  <table style="width:100%; border-collapse: collapse;" id="listTable">
    <thead>
      <tr style="background:#f8f9fa; text-align:left;">
        <th style="padding:10px; border-bottom:2px solid #ddd;">日期</th>
        <th style="padding:10px; border-bottom:2px solid #ddd;">時段</th>
        <th style="padding:10px; border-bottom:2px solid #ddd; text-align:right;">操作</th>
      </tr>
    </thead>
    <tbody id="listBody"></tbody>
  </table>
</div>

<style>
  .time-box { display: flex; align-items: center; background: #f1f3f5; padding: 8px; border-radius: 4px; cursor: pointer; }
  .time-box:hover { background: #e9ecef; }
  .time-box input { margin-right: 5px; transform: scale(1.2); }
  .del-btn { background: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; }
</style>

<script>
  // 你的 Google Apps Script 網址
  const API_URL = "https://script.google.com/macros/s/AKfycbyWvhW6fp_ohPEvPK226KtNiQLCyAVMl77zV0Hq0k_TcEk3F1ni9qVcJystGUovVjTMGQ/exec";

  // 初始化：嘗試載入清單，但失敗不會卡死按鈕
  loadList();

  function checkSunday() {
    const val = document.getElementById('admDate').value;
    if(!val) return;
    const date = new Date(val);
    if(date.getDay() !== 0) {
      alert("請選擇週日！");
      document.getElementById('admDate').value = "";
    }
  }

  function loadList() {
    const loadDiv = document.getElementById('loading');
    loadDiv.style.display = 'block';
    
    // 使用 POST 避免快取問題，增加連線成功率
    fetch(API_URL, {
      method: 'POST',
      body: JSON.stringify({ action: "get_exceptions_list" }) // 改用 POST 讀取
    })
    .then(r => r.json())
    .then(data => {
        loadDiv.style.display = 'none';
        renderTable(data);
    })
    .catch(e => {
        console.error(e);
        loadDiv.innerText = "目前無資料或連線緩慢 (不影響新增功能)";
    });
  }

  function renderTable(list) {
    const tbody = document.getElementById('listBody');
    tbody.innerHTML = "";
    
    if(!list || list.length === 0) {
        tbody.innerHTML = "<tr><td colspan='3' style='padding:20px; text-align:center; color:#999;'>無開放資料</td></tr>";
        return;
    }

    list.forEach(item => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td style="padding:10px; border-bottom:1px solid #eee; color:blue; font-weight:bold;">${item.date}</td>
        <td style="padding:10px; border-bottom:1px solid #eee;">${item.slots.join(', ')}</td>
        <td style="padding:10px; border-bottom:1px solid #eee; text-align:right;">
          <button class="del-btn" onclick="deleteItem('${item.date}')">刪除</button>
        </td>
      `;
      tbody.appendChild(tr);
    });
  }

  function addException() {
    const date = document.getElementById('admDate').value;
    if(!date) return alert("請先選擇日期");
    
    const checkboxes = document.querySelectorAll('input[type="checkbox"]:checked');
    let slots = [];
    checkboxes.forEach(cb => slots.push(cb.value));
    
    if(slots.length === 0) return alert("請至少勾選一個時段");

    const btn = document.getElementById('addBtn');
    const msg = document.getElementById('statusMsg');
    
    btn.innerText = "資料傳送中...";
    btn.disabled = true;
    msg.innerText = "";

    fetch(API_URL, {
      method: 'POST',
      body: JSON.stringify({ action: "add_exception", date: date, slots: slots })
    })
    .then(r => r.json())
    .then(data => {
      btn.disabled = false;
      btn.innerText = "新增開放時段";
      
      if(data.success) {
        msg.style.color = "green";
        msg.innerText = "✅ 新增成功！";
        if(data.list) renderTable(data.list);
        // 清空勾選
        document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
      } else {
        msg.style.color = "red";
        msg.innerText = "❌ 錯誤：" + (data.message || "未知錯誤");
      }
    })
    .catch(e => {
      btn.disabled = false;
      btn.innerText = "新增開放時段";
      msg.style.color = "red";
      msg.innerText = "❌ 連線失敗，請檢查後端是否已部署為新版本";
      alert("連線失敗：" + e);
    });
  }

  function deleteItem(date) {
    if(!confirm("確定要取消 " + date + " 的開放時段嗎？")) return;
    
    fetch(API_URL, {
      method: 'POST',
      body: JSON.stringify({ action: "delete_exception", date: date })
    })
    .then(r => r.json())
    .then(data => {
      if(data.success && data.list) renderTable(data.list);
      else alert("刪除失敗");
    })
    .catch(e => alert("連線錯誤"));
  }
</script>
