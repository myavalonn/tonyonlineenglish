<script>
  window.onload = function() {
    const d = new Date();
    document.getElementById('inDate').value = d.toISOString().split('T')[0];
    refreshData();
  }

  function refreshData() {
    const v = (id, def) => document.getElementById(id).value || def;
    
    const rawAmount = v('inAmount', '12000');
    const fmtAmount = new Intl.NumberFormat('en-US').format(rawAmount);
    
    const date = v('inDate', '2025-11-20');
    const classes = v('inClasses', '20');
    const mins = v('inMins', '50');
    const expiry = v('inExpiry', '2年');
    const order = v('inOrder', '15TEY');
    const points = v('inPoints', '900');

    // P1 (CN)
    document.getElementById('outNameCN').innerText = v('inNameCN', '葉宥淇');
    document.getElementById('outCourseCNDisplay').innerText = v('inCourseCN', '生活會話');
    
    let timeCN = v('inTimeCN', '每週一 8pm');
    document.getElementById('outTimeCN').innerHTML = timeCN.replace(/\s+/g, '<br>');

    document.getElementById('outAmountNumCN').innerText = fmtAmount; 
    document.getElementById('outOrderCN').innerText = order;
    document.getElementById('outClassesCN').innerText = classes;
    document.getElementById('outMinsCN').innerText = mins;
    document.getElementById('outDateCN').innerText = date;
    document.getElementById('outExpiryCN').innerText = expiry;
    document.getElementById('outPointsCN').innerText = points;

    // P2 (EN)
    document.getElementById('outNameEN').innerText = v('inNameEN', 'Tony Lin');
    document.getElementById('outCourseENDisplay').innerText = v('inCourseEN', 'Daily Conversation');
    
    let timeEN = v('inTimeEN', '8pm, Mondays');
    document.getElementById('outTimeEN').innerHTML = timeEN.replace(/\s+/g, '<br>');

    document.getElementById('outAmountNumEN').innerText = fmtAmount; 
    document.getElementById('outOrderEN').innerText = order;
    document.getElementById('outClassesEN').innerText = classes;
    document.getElementById('outMinsEN').innerText = mins;
    document.getElementById('outDateEN').innerText = date;
    document.getElementById('outPointsEN').innerText = points;
    
    let exEn = v('inExpiryEN', '2 Years');
    document.getElementById('outExpiryEN').innerText = exEn;

    // P4 (SUB)
    document.getElementById('outOrderSub').innerText = order;
  }

  function downloadPDF() {
    const element = document.getElementById('pdf-container');
    const nameEN = document.getElementById('inNameEN').value || "Student";
    
    const opt = {
      margin:       0,
      filename:     `${nameEN}_Tuition_Certificate_V98.pdf`,
      image:        { type: 'jpeg', quality: 1.0 },
      html2canvas:  { scale: 4, useCORS: true, scrollY: 0 },
      // Strict height control to prevent 5th page
      jsPDF:        { unit: 'mm', format: [108, 195], orientation: 'portrait' }
    };
    html2pdf().set(opt).from(element).save();
  }
</script>
