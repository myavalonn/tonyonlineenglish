<script>
  window.onload = function() {
    const d = new Date();
    document.getElementById('inDate').value = d.toISOString().split('T')[0];
    refreshData();
  }

  function refreshData() {
    const v = (id, def) => document.getElementById(id).value || def;
    
    const rawAmount = v('inAmount', '3000');
    const fmtAmount = new Intl.NumberFormat('en-US').format(rawAmount);
    
    const date = v('inDate', '2025-11-20');
    const order = v('inOrder', '#L8ACX');
    const expiry = v('inExpiry', '無期限');
    
    const writingQty = v('inWritingQty', '4');
    const courseQty = v('inCourseQty', '2');
    
    // P1 (CN)
    document.getElementById('outNameCN').innerText = document.getElementById('inNameCN').value || '--';
    document.getElementById('outTimeCN').innerText = v('inTimeCN', '') || '--';

    document.getElementById('outAmountNumCN').innerText = fmtAmount; 
    document.getElementById('outOrderCN').innerText = order;
    document.getElementById('outDateCN').innerText = date;
    document.getElementById('outExpiryCN').innerText = expiry;
    
    document.getElementById('outWritingQtyCN').innerText = writingQty;
    document.getElementById('outCourseQtyCN').innerText = courseQty;

    // P2 (EN)
    document.getElementById('outNameEN').innerText = document.getElementById('inNameEN').value || '--';
    document.getElementById('outTimeEN').innerText = v('inTimeEN', '') || '--';

    document.getElementById('outAmountNumEN').innerText = fmtAmount; 
    document.getElementById('outOrderEN').innerText = order;
    document.getElementById('outDateEN').innerText = date;
    document.getElementById('outExpiryEN').innerText = v('inExpiryEN', 'No Expiration');
    
    document.getElementById('outWritingQtyEN').innerText = writingQty;
    document.getElementById('outCourseQtyEN').innerText = courseQty;
  }

  function downloadPDF() {
    const element = document.getElementById('pdf-container');
    const nameEN = document.getElementById('inNameEN').value || "Student";
    const orderID = document.getElementById('inOrder').value || "Order";
    
    const opt = {
      margin:       0,
      filename:     `${orderID}_${nameEN}_Certificate.pdf`,
      image:        { type: 'jpeg', quality: 1.0 },
      html2canvas:  { scale: 4, useCORS: true, scrollY: 0 },
      jsPDF:        { unit: 'mm', format: [108, 192], orientation: 'portrait' }
    };
    html2pdf().set(opt).from(element).save();
  }
</script>
