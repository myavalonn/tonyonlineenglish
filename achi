      font-size: 1.05rem;
      margin-bottom: 0.3rem;
    }

    .achievement-desc {
      font-size: 0.9rem;
      color: #444;
    }

    /* 背景顏色每格不同 */
    .achievement-card:nth-child(1)  { background: #FFF8E1; }
    .achievement-card:nth-child(2)  { background: #E1F5FE; }
    .achievement-card:nth-child(3)  { background: #F1F8E9; }
    .achievement-card:nth-child(4)  { background: #FCE4EC; }
    .achievement-card:nth-child(5)  { background: #E8F5E9; }
    .achievement-card:nth-child(6)  { background: #F3E5F5; }
    .achievement-card:nth-child(7)  { background: #FFF3E0; }
    .achievement-card:nth-child(8)  { background: #E0F7FA; }
    .achievement-card:nth-child(9)  { background: #FFEBEE; }
    .achievement-card:nth-child(10) { background: #EDE7F6; }
    .achievement-card:nth-child(11) { background: #F1F8FF; }
    .achievement-card:nth-child(12) { background: #FFFDE7; }
  </style>

